# Stripe (test mode). Leave unset to run the portal in DEMO_MODE,
# which skips the checkout step and jumps straight to release issuance.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Base URL used to build Stripe redirect URLs and attendant QR links.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Simple attendant passcode for the prototype. Change before any demo.
ATTENDANT_PIN=8421
